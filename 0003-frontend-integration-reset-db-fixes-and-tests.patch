+        _make_claim(ephemeral_db, b.id, "P2", c.id)
+        _make_claim(ephemeral_db, c.id, "P3", d.id)
+        _make_claim(ephemeral_db, d.id, "P4", e.id)
+        _make_rule(ephemeral_db, "P1", "P2", "Q1")
+        _make_rule(ephemeral_db, "Q1", "P3", "Q2")
